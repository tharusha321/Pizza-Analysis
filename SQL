--Master KPI's--

CREATE OR REPLACE VIEW `pizza_analytics.view_master_kpis` AS
SELECT
  DATE(o.date) AS order_date,

 -- 1. Total Orders & Total Pizzas Sold
  COUNT(DISTINCT o.order_id) AS total_orders,
  SUM(od.quantity) AS total_pizzas_sold,

-- 2. Total Revenue
  ROUND(SUM(od.quantity * p.price), 2) AS total_revenue,

-- 3. Average Order Value (Revenue / Total Orders)
  ROUND(SUM(od.quantity * p.price) / COUNT(DISTINCT o.order_id), 2) AS average_order_value,

-- 4. Average Pizzas Per Order (Total Pizzas / Total Orders)
ROUND(SUM(od.quantity) / COUNT(DISTINCT o.order_id), 2) AS avg_pizzas_per_order

FROM `pizza_analytics.orders` o 
LEFT JOIN `pizza_analytics.order_details` od ON o.order_id = od.order_id
LEFT JOIN `pizza_analytics.pizzas` p ON od.pizza_id = p.pizza_id
GROUP BY 1;

--Chart Trends--

CREATE OR REPLACE VIEW `pizza_analytics.view_chart_trends` AS
SELECT
  DATE(o.date) AS order_date,
  EXTRACT(HOUR FROM TIME(o.time)) AS order_hour,
  SUM(od.quantity) AS total_pizza_sold
FROM `pizza_analytics.orders` o 
LEFT JOIN `pizza_analytics.order_details` od ON o.order_id = od.order_id
GROUP BY 1, 2;

--Chart Products--

CREATE OR REPLACE VIEW `pizza_analytics.view_chart_products` AS 
SELECT
  pt.pizza_name,
  pt.category AS pizza_category,
  p.size AS pizza_size,
  SUM(od.quantity) AS  total_quantity,
  COUNT(DISTINCT o.order_id) AS total_orders,
  ROUND(SUM(od.quantity * p.price), 2) AS total_revenue
FROM `pizza_analytics.orders` o
LEFT JOIN `pizza_analytics.order_details` od ON o.order_id = od.order_id
LEFT JOIN `pizza_analytics.pizzas` p ON od.pizza_id = p.pizza_id
LEFT JOIN `pizza_analytics.pizza_types` pt ON p.pizza_type_id = pt.pizza_type_id
GROUP BY 1, 2, 3;
